<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GrannyManager.App.Avalonia.Views.SplashWindow"
        Title="Home &amp; Family Finance Manager"
        Width="520"
        Height="300"
        MinWidth="520"
        MinHeight="300"
        MaxWidth="520"
        MaxHeight="300"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        Background="#0B1624"
        Topmost="True">

    <Border Background="#122238"
            BorderBrush="#2A405A"
            BorderThickness="1"
            CornerRadius="10"
            Padding="28">

        <Grid RowDefinitions="*,Auto"
              RowSpacing="18">

            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        Spacing="10">

                <TextBlock Text="Home &amp; Family"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Finance Manager"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Build 0.10.47"
                           Foreground="#8FBCE8"
                           FontSize="13"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

                <Border Background="#0F1B2A"
                        BorderBrush="#26384F"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="14"
                        Margin="0,18,0,0">

                    <StackPanel Spacing="8">
                        <TextBlock Text="Preparing your workspace"
                                   Foreground="#DDE7F3"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>

                        <ProgressBar IsIndeterminate="True"
                                     Height="4"
                                     Width="360"
                                     Background="#17263A"
                                     Foreground="#2F80C1"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Grid.Row="1"
                       Name="StatusTextBlock"
                       Text="Starting Home &amp; Family Finance Manager..."
                       Foreground="#9EB4CC"
                       FontSize="12"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
        </Grid>
    </Border>
</Window>
