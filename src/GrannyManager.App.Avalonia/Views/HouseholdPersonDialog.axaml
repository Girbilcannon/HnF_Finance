<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GrannyManager.App.Avalonia.Views.HouseholdPersonDialog"
        Title="Household Member"
        Width="560"
        Height="720"
        MinWidth="520"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="#101C2C">

    <Border Background="#122238"
            BorderBrush="#2A405A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22">

        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="18">

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Name="DialogTitleTextBlock"
                           Text="Household Member"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Add household members, caretakers, contributors, and related family contacts."
                           Foreground="#B8CBE0"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="14">

                    <StackPanel Spacing="5">
                        <TextBlock Text="Full Name" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="FullNameTextBox"
                                 Padding="12"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12">
                        <StackPanel Grid.Column="0" Spacing="5">
                            <TextBlock Text="Relationship" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                            <TextBox Name="RelationshipTextBox"
                                     Watermark="Self, Spouse, Child, Caregiver..."
                                     Padding="12"
                                     Background="#0F1B2A"
                                     Foreground="White"
                                     BorderBrush="#30445F"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="5">
                            <TextBlock Text="Role / Purpose" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                            <TextBox Name="RoleTextBox"
                                     Watermark="Primary Person, Helper, Contributor..."
                                     Padding="12"
                                     Background="#0F1B2A"
                                     Foreground="White"
                                     BorderBrush="#30445F"/>
                        </StackPanel>
                    </Grid>

                    <Border Background="#0F1B2A"
                            BorderBrush="#26384F"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Household / Financial Load"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>

                            <CheckBox Name="LivesInHouseholdCheckBox"
                                      Content="Lives in household"
                                      Foreground="#DDE7F3"/>

                            <CheckBox Name="PaysRentCheckBox"
                                      Content="Pays rent or contributes financially"
                                      Foreground="#DDE7F3"/>

                            <CheckBox Name="UsesHouseholdVehicleCheckBox"
                                      Content="Uses household vehicle"
                                      Foreground="#DDE7F3"/>

                            <CheckBox Name="ReceivesRidesCheckBox"
                                      Content="Receives rides / transportation help"
                                      Foreground="#DDE7F3"/>

                            <Grid ColumnDefinitions="210,*"
                                  ColumnSpacing="10">
                                <TextBlock Grid.Column="0"
                                           Text="Monthly Contribution to Household"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <ComboBox Name="ContributionHandlingComboBox"
                                          Grid.Column="1"
                                          Background="#0F1B2A"
                                          Foreground="White"
                                          BorderBrush="#30445F"
                                          MinHeight="36">
                                    <ComboBoxItem Content="No Contribution"/>
                                    <ComboBoxItem Content="Select Income Source"/>
                                    <ComboBoxItem Content="Add Income Source"/>
                                </ComboBox>
                            </Grid>

                            <Grid Name="LinkedIncomeSourcePanel"
                                  ColumnDefinitions="210,*"
                                  ColumnSpacing="10"
                                  IsVisible="False">
                                <TextBlock Grid.Column="0"
                                           Text="Linked Income Source"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <ComboBox Name="LinkedIncomeSourceComboBox"
                                          Grid.Column="1"
                                          Background="#0F1B2A"
                                          Foreground="White"
                                          BorderBrush="#30445F"
                                          MinHeight="36"
                                          IsEnabled="False">
                                    <ComboBoxItem Content="Income source linking will be available after the Income section is wired."/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <CheckBox Name="IsActiveCheckBox"
                              Content="Active household record"
                              Foreground="#DDE7F3"/>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Notes" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="NotesTextBox"
                                 MinHeight="140"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Padding="12"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"/>
                    </StackPanel>

                    <TextBlock Name="ValidationTextBlock"
                               Text=""
                               Foreground="#FFB0B0"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">

                <Button Name="CancelButton"
                        Content="Cancel"
                        Height="38"
                        Padding="18,0"
                        Background="#17263A"
                        Foreground="#DDE7F3"
                        BorderBrush="#30445F"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>

                <Button Name="SaveButton"
                        Content="Save"
                        Height="38"
                        Padding="18,0"
                        Background="#2E8B57"
                        Foreground="White"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
