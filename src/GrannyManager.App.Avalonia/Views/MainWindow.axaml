<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GrannyManager.App.Avalonia.ViewModels"
        xmlns:sections="using:GrannyManager.App.Avalonia.Views.Sections"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="GrannyManager.App.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Home &amp; Family Finance Manager"
        Width="1280"
        Height="800"
        MinWidth="1180"
        MinHeight="760"
        Background="#0B1624">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.nav-button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#DDE7F3"/>
        </Style>

        <Style Selector="Button.nav-button:pointerover">
            <Setter Property="Background" Value="#17263A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="Button.nav-button.selected">
            <Setter Property="Background" Value="#1A2B42"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="260,*"
          RowDefinitions="Auto,*"
          Background="#0B1624">

        <!-- Sidebar -->
        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="#101D2D"
                BorderBrush="#26384F"
                BorderThickness="0,0,1,0"
                Padding="18">

            <Grid RowDefinitions="Auto,*,Auto">

                <!-- App title -->
                <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
                    <TextBlock Text="Home &amp; Family"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Finance Manager"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Spacing="8">
                    <Button Content="Dashboard"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Dashboard"
                            Classes.selected="{Binding IsDashboardSelected}"/>

                    <Button Content="Household"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Household"
                            Classes.selected="{Binding IsHouseholdSelected}"/>

                    <Button Content="Income"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Income"
                            Classes.selected="{Binding IsIncomeSelected}"/>

                    <Button Content="Bills"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Bills"
                            Classes.selected="{Binding IsBillsSelected}"/>

                    <Button Content="Allowance / Savings"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="AllowanceSavings"
                            Classes.selected="{Binding IsAllowanceSavingsSelected}"/>

                    <Button Content="Assets"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Assets"
                            Classes.selected="{Binding IsAssetsSelected}"/>

                    <Button Content="Debts"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Debts"
                            Classes.selected="{Binding IsDebtsSelected}"/>

                    <Button Content="Documents"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Documents"
                            Classes.selected="{Binding IsDocumentsSelected}"/>

                    <Button Content="Password Vault"
                            Classes="nav-button"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="PasswordVault"
                            Classes.selected="{Binding IsPasswordVaultSelected}"/>
                </StackPanel>

                <!-- Build / copyright footer -->
                <StackPanel Grid.Row="2"
                            Spacing="4"
                            Margin="2,18,0,0">
                    <TextBlock Text="Build: 0.10.37"
                               Foreground="#6F8299"
                               FontSize="12"/>

                    <TextBlock Text="© 2026 Aaron Marine"
                               Foreground="#6F8299"
                               FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top bar -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Background="#0F1B2A"
                BorderBrush="#26384F"
                BorderThickness="0,0,0,1"
                Padding="22,16">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">

                <TextBox Grid.Column="0"
                         Watermark="Search for documents, names, keywords, etc."
                         FontSize="15"
                         Height="42"
                         Padding="14,8"
                         Background="#17263A"
                         Foreground="White"
                         BorderBrush="#30445F"
                         BorderThickness="1"/>

                <Button Grid.Column="1"
                        Content="Help"
                        Height="42"
                        Padding="18,0"
                        Background="#17263A"
                        Foreground="#DDE7F3"
                        BorderBrush="#30445F"
                        FontWeight="SemiBold"
                        Command="{Binding HelpCommand}"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Main content frame -->
        <Grid Grid.Row="1"
              Grid.Column="1"
              RowDefinitions="Auto,Auto,*"
              Margin="28">

            <!-- Summary bar retained at top -->
            <Border Grid.Row="0"
                    Background="#122238"
                    BorderBrush="#2A405A"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="0">

                <Grid ColumnDefinitions="0.95*,0.95*,1.25*,1.0*">

                    <Border Grid.Column="0" Padding="16,13" BorderBrush="#243951" BorderThickness="0,0,1,0">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Monthly Income"
                                       Foreground="#9EB4CC"
                                       FontSize="13"/>
                            <TextBlock Text="$0.00"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Padding="16,13" BorderBrush="#243951" BorderThickness="0,0,1,0">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Monthly Bills"
                                       Foreground="#9EB4CC"
                                       FontSize="13"/>
                            <TextBlock Text="$0.00"
                                       Foreground="White"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="16,13" BorderBrush="#243951" BorderThickness="0,0,1,0">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Allowance / Savings"
                                       Foreground="#9EB4CC"
                                       FontSize="13"/>
                            <TextBlock Text="$0.00 / $0.00"
                                       Foreground="White"
                                       FontSize="23"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Padding="16,13">
                        <StackPanel Spacing="5">
                            <TextBlock Text="Remaining / Deficit"
                                       Foreground="#9EB4CC"
                                       FontSize="13"/>
                            <TextBlock Text="$0.00"
                                       Foreground="#D9534F"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Current section heading -->
            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  Margin="0,20,0,18">

                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="{Binding CurrentPageTitle}"
                               Foreground="White"
                               FontSize="30"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="{Binding CurrentPageSubtitle}"
                               Foreground="#AFC0D3"
                               FontSize="15"
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsNotDashboardSelected}"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Spacing="12"
                            IsVisible="{Binding IsDashboardSelected}">

                    <StackPanel Spacing="2">
                        <TextBlock Text=" "
                                   Foreground="#8FBCE8"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>

                        <Button Name="StartNewCaseButton"
                                Content="Start New Case"
                                Height="40"
                                Padding="18,0"
                                Background="#2E8B57"
                                Foreground="White"
                                FontWeight="SemiBold"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock Text="Need help getting started?"
                                   Foreground="#8FBCE8"
                                   FontSize="10"
                                   HorizontalAlignment="Center"/>

                        <Button Content="Case Setup Wizard"
                                Height="40"
                                Padding="18,0"
                                Background="#17263A"
                                Foreground="#DDE7F3"
                                BorderBrush="#30445F"
                                Command="{Binding Dashboard.StartWizardCommand}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Section body -->
            <Grid Grid.Row="2">

                <Grid IsVisible="{Binding IsDashboardSelected}">
                    <sections:DashboardView DataContext="{Binding Dashboard}"/>
                </Grid>

                <Grid IsVisible="{Binding IsHouseholdSelected}">
                    <sections:HouseholdView DataContext="{Binding Household}"/>
                </Grid>

                <Grid IsVisible="{Binding IsIncomeSelected}">
                    <sections:IncomeView DataContext="{Binding Income}"/>
                </Grid>

                <Grid IsVisible="{Binding IsBillsSelected}">
                    <sections:BillsView DataContext="{Binding Bills}"/>
                </Grid>

                <Grid IsVisible="{Binding IsAllowanceSavingsSelected}">
                    <sections:AllowanceSavingsView DataContext="{Binding AllowanceSavings}"/>
                </Grid>

                <Grid IsVisible="{Binding IsAssetsSelected}">
                    <sections:AssetsView DataContext="{Binding Assets}"/>
                </Grid>

                <Grid IsVisible="{Binding IsDebtsSelected}">
                    <sections:DebtsView DataContext="{Binding Debts}"/>
                </Grid>

                <Grid IsVisible="{Binding IsDocumentsSelected}">
                    <sections:DocumentsView DataContext="{Binding Documents}"/>
                </Grid>

                <Border IsVisible="{Binding IsGenericPlaceholderVisible}"
                        Background="#122238"
                        BorderBrush="#2A405A"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="22">

                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding CurrentPageCardTitle}"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="{Binding CurrentPageBody}"
                                   Foreground="#C8D4E2"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="This placeholder confirms the shell navigation is working. The next step is replacing each placeholder with a real page view."
                                   Foreground="#8FA3BA"
                                   FontSize="14"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
