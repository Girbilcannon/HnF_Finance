<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GrannyManager.App.Avalonia.Views.AllowanceSavingsItemDialog"
        Title="Allowance / Savings Item"
        Width="600"
        Height="760"
        MinWidth="560"
        MinHeight="660"
        WindowStartupLocation="CenterOwner"
        Background="#101C2C">

    <Border Background="#122238"
            BorderBrush="#2A405A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22">
        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="18">
            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Name="DialogTitleTextBlock"
                           Text="Allowance / Savings Item"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Track planned allowance, savings, envelopes, cash reserves, or bank-held set-asides."
                           Foreground="#B8CBE0"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="5">
                        <TextBlock Text="Name"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBox Name="ItemNameTextBox"
                                 Padding="12"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Storage / Account"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <ComboBox Name="StorageMethodComboBox"
                                  Background="#0F1B2A"
                                  Foreground="White"
                                  BorderBrush="#30445F"
                                  MinHeight="36">
                            <ComboBoxItem Content="Cash/Check"/>
                            <ComboBoxItem Content="Select Bank Account"/>
                            <ComboBoxItem Content="Select Multiple Bank Accounts"/>
                            <ComboBoxItem Content="Other"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Name="WhereStoredPanel"
                                Spacing="5"
                                IsVisible="False">
                        <TextBlock Text="Storage Details"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBox Name="WhereStoredTextBox"
                                 Watermark="Optional notes"
                                 Padding="12"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"/>
                    </StackPanel>

                    <StackPanel Name="BankAccountPanel"
                                Spacing="5"
                                IsVisible="False">
                        <TextBlock Text="Bank Account"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <ComboBox Name="BankAccountComboBox"
                                  Background="#0F1B2A"
                                  Foreground="White"
                                  BorderBrush="#30445F"
                                  MinHeight="36">
                            <ComboBoxItem Content="Choose account"/>
                        </ComboBox>

                        <Button Name="CreateBankAccountButton"
                                Content="+ Create Bank Account"
                                Height="34"
                                Padding="12,0"
                                Background="#2E8B57"
                                Foreground="White"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Name="MultipleBankAccountsPanel"
                                Spacing="8"
                                IsVisible="False">
                        <TextBlock Text="Bank accounts / deposit amounts"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10">
                            <StackPanel Spacing="8">
                                <StackPanel Name="MultipleBankAccountsHost"
                                            Spacing="8"/>

                                <Button Name="AddBankAccountLineButton"
                                        Content="+ Add Bank Account Line"
                                        Height="34"
                                        Padding="12,0"
                                        Background="#2E8B57"
                                        Foreground="White"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Button Name="CreateBankAccountForMultipleButton"
                                Content="+ Create Bank Account"
                                Height="34"
                                Padding="12,0"
                                Background="#2E8B57"
                                Foreground="White"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Name="OtherStoragePanel"
                                Spacing="5"
                                IsVisible="False">
                        <TextBlock Text="Other Storage Method"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBox Name="OtherStorageMethodTextBox"
                                 Padding="12"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"/>
                    </StackPanel>

                    <CheckBox Name="IsActiveCheckBox"
                              Content="Active allowance/savings item"
                              Foreground="#DDE7F3"/>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Notes"
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBox Name="NotesTextBox"
                                 MinHeight="120"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Padding="12"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"/>
                    </StackPanel>

                    <TextBlock Name="ValidationTextBlock"
                               Text=""
                               Foreground="#FFB0B0"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="10">
                <Button Name="CancelButton"
                        Content="Cancel"
                        Height="38"
                        Padding="18,0"
                        Background="#17263A"
                        Foreground="#DDE7F3"
                        BorderBrush="#30445F"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
                <Button Name="SaveButton"
                        Content="Save"
                        Height="38"
                        Padding="18,0"
                        Background="#2E8B57"
                        Foreground="White"
                        FontWeight="SemiBold"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
