<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GrannyManager.App.Avalonia.Views.PasswordVaultEntryDialog"
        Title="Password Vault Entry"
        Width="560"
        Height="650"
        MinWidth="520"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#0B1624">

    <Border Background="#122238"
            BorderBrush="#2A405A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22">

        <Grid RowDefinitions="Auto,*,Auto"
              RowSpacing="16">

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock Name="TitleTextBlock"
                           Text="Add Vault Entry"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Passwords are saved inside the encrypted case vault."
                           Foreground="#AFC0D3"
                           FontSize="13"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="12">

                    <StackPanel Spacing="5">
                        <TextBlock Text="Title" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="EntryTitleTextBox" Height="38" Padding="12,7" Background="#0F1B2A" Foreground="White" BorderBrush="#30445F"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Website / URL" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="WebsiteTextBox" Height="38" Padding="12,7" Background="#0F1B2A" Foreground="White" BorderBrush="#30445F"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Username / Email" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="UserNameTextBox" Height="38" Padding="12,7" Background="#0F1B2A" Foreground="White" BorderBrush="#30445F"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Password" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="PasswordTextBox" Height="38" Padding="12,7" PasswordChar="●" Background="#0F1B2A" Foreground="White" BorderBrush="#30445F"/>
                    </StackPanel>

                    <StackPanel Spacing="5">
                        <TextBlock Text="Notes" Foreground="#9EB4CC" FontSize="12" FontWeight="SemiBold"/>
                        <TextBox Name="NotesTextBox" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" Padding="12" Background="#0F1B2A" Foreground="White" BorderBrush="#30445F"/>
                    </StackPanel>

                    <TextBlock Name="ValidationTextBlock" Foreground="#FFD6DD" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="10">
                <Button Grid.Column="1" Name="CancelButton" Content="Cancel" Height="38" Padding="18,0" Background="#17263A" Foreground="#DDE7F3" BorderBrush="#30445F" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Name="SaveButton" Content="Save Entry" Height="38" Padding="18,0" Background="#2E8B57" Foreground="White" FontWeight="SemiBold" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            </Grid>
        </Grid>
    </Border>
</Window>
