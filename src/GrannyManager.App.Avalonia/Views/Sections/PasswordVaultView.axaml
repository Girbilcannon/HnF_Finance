<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GrannyManager.App.Avalonia.Views.Sections.PasswordVaultView">

    <Grid ColumnDefinitions="520,*"
          ColumnSpacing="18">

        <!-- Vault control card -->
        <Border Grid.Column="0"
                Background="#122238"
                BorderBrush="#2A405A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  RowSpacing="14">

                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Password Vault"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Protected by the active case security PIN."
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Lock Vault"
                            Height="34"
                            Padding="14,0"
                            Background="#17263A"
                            Foreground="#DDE7F3"
                            BorderBrush="#30445F"
                            IsVisible="{Binding IsUnlocked}"
                            Command="{Binding LockVaultCommand}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"/>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#8FA3BA"
                           FontSize="12"
                           TextWrapping="Wrap"/>

                <Border Grid.Row="2"
                        Background="#0F1B2A"
                        BorderBrush="#26384F"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16"
                        IsVisible="{Binding IsLocked}">

                    <StackPanel Spacing="12">
                        <TextBlock Text="Vault locked"
                                   Foreground="White"
                                   FontSize="17"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Enter the active case PIN to unlock this vault. If this case does not have a vault yet, an encrypted vault file will be created."
                                   Foreground="#C8D4E2"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>

                        <Grid ColumnDefinitions="150,*"
                              ColumnSpacing="10">
                            <TextBox Grid.Column="0"
                                     Name="VaultPinTextBox"
                                     Watermark="4-digit PIN"
                                     MaxLength="4"
                                     PasswordChar="●"
                                     Height="38"
                                     Padding="12,7"
                                     Text="{Binding Pin}"
                                     Background="#0B1624"
                                     Foreground="White"
                                     BorderBrush="#30445F"
                                     IsEnabled="{Binding CanUnlock}"/>

                            <Button Grid.Column="1"
                                    Name="UnlockVaultButton"
                                    Content="Unlock Vault"
                                    Height="38"
                                    Padding="16,0"
                                    Background="#2E8B57"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    IsEnabled="{Binding CanUnlock}"
                                    Command="{Binding UnlockVaultCommand}"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Background="#0F1B2A"
                        BorderBrush="#26384F"
                        BorderThickness="1"
                        CornerRadius="6"
                        IsVisible="{Binding IsUnlocked}">

                    <Grid RowDefinitions="36,*">

                        <Border Grid.Row="0"
                                Background="#17263A"
                                BorderBrush="#26384F"
                                BorderThickness="0,0,0,1"
                                Padding="12,0">
                            <Grid ColumnDefinitions="1.1*,0.9*,0.9*,0.7*"
                                  ColumnSpacing="10">
                                <TextBlock Text="Title"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="Username"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="2"
                                           Text="Website"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="3"
                                           Text="Updated"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <ListBox ItemsSource="{Binding Items}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#26384F"
                                                BorderThickness="0,0,0,1"
                                                Padding="12"
                                                Background="#0F1B2A">
                                            <Grid ColumnDefinitions="1.1*,0.9*,0.9*,0.7*"
                                                  ColumnSpacing="10">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="White"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding UserName}"
                                                           Foreground="#C8D4E2"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Website}"
                                                           Foreground="#9EB4CC"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <TextBlock Grid.Column="3"
                                                           Text="{Binding UpdatedText}"
                                                           Foreground="#8FA3BA"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="6"
                                        IsVisible="{Binding IsUnlocked}">
                                <TextBlock Text="No password entries have been added yet."
                                           Foreground="#C8D4E2"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Add/Edit/Delete entries will be wired in the next vault pass."
                                           Foreground="#8FA3BA"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="4"
                           Text="{Binding VaultPath}"
                           Foreground="#60758E"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <!-- Vault profile/details card -->
        <Border Grid.Column="1"
                Background="#122238"
                BorderBrush="#2A405A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">

            <Grid RowDefinitions="Auto,*"
                  RowSpacing="16">

                <WrapPanel Grid.Row="0"
                           Orientation="Horizontal"
                           HorizontalAlignment="Stretch">
                    <TextBlock Text="Vault Details"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Margin="0,0,16,8"
                               VerticalAlignment="Center"/>
                </WrapPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel Spacing="14">
                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Security foundation"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="This first pass creates and unlocks an encrypted vault file only after the active case PIN is verified. The vault file stores encrypted JSON, not plain text password records."
                                           Foreground="#C8D4E2"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>

                                <TextBlock Text="Current file:"
                                           Foreground="#9EB4CC"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0"/>

                                <TextBlock Text="{Binding VaultPath}"
                                           Foreground="#8FA3BA"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Next vault pass"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="Next we can add real password entries: title, username, password, website, notes, copy buttons, edit/remove buttons, and a safer auto-lock timer."
                                           Foreground="#C8D4E2"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
