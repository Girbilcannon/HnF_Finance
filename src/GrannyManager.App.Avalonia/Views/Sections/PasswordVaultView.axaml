<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GrannyManager.App.Avalonia.Views.Sections.PasswordVaultView">


    <UserControl.Styles>
        <Style Selector="ListBox.vault-list">
            <Setter Property="Background" Value="#0F1B2A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style Selector="ListBox.vault-list ListBoxItem">
            <Setter Property="Background" Value="#0F1B2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="ListBox.vault-list ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2F80C1"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox.vault-list ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#173A5A"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="ListBox.vault-list ListBoxItem:focus /template/ ContentPresenter">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="520,*"
          ColumnSpacing="18">

        <Border Grid.Column="0"
                Background="#122238"
                BorderBrush="#2A405A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">

            <Grid RowDefinitions="Auto,Auto,Auto,*,Auto"
                  RowSpacing="14">

                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">

                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Password Vault"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Protected by the active case security PIN."
                                   Foreground="#9EB4CC"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Name="AddVaultEntryButton"
                                Content="+ Add Entry"
                                Height="34"
                                Padding="14,0"
                                Background="#2E8B57"
                                Foreground="White"
                                FontWeight="SemiBold"
                                IsVisible="{Binding IsUnlocked}"
                                IsEnabled="{Binding CanAddEntry}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>

                        <Button Content="Lock Vault"
                                Height="34"
                                Padding="14,0"
                                Background="#17263A"
                                Foreground="#DDE7F3"
                                BorderBrush="#30445F"
                                IsVisible="{Binding IsUnlocked}"
                                Command="{Binding LockVaultCommand}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#9EB4CC"
                           FontSize="12"
                           TextWrapping="Wrap"/>

                <Border Grid.Row="2"
                        IsVisible="{Binding IsLocked}"
                        Background="#0F1B2A"
                        BorderBrush="#26384F"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Vault Locked"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Enter the active case PIN to unlock the protected vault."
                                   Foreground="#C8D4E2"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>

                        <TextBox Name="VaultPinTextBox"
                                 Text="{Binding Pin, Mode=TwoWay}"
                                 Watermark="Case PIN"
                                 PasswordChar="●"
                                 Height="36"
                                 Padding="12,0"
                                 Background="#0F1B2A"
                                 Foreground="White"
                                 BorderBrush="#30445F"
                                 VerticalContentAlignment="Center"/>

                        <Button Name="UnlockVaultButton"
                                Command="{Binding UnlockVaultCommand}"
                                Content="Unlock Vault"
                                Height="36"
                                Padding="16,0"
                                Background="#2E8B57"
                                Foreground="White"
                                FontWeight="SemiBold"
                                HorizontalAlignment="Left"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        IsVisible="{Binding IsUnlocked}"
                        Background="#0F1B2A"
                        BorderBrush="#26384F"
                        BorderThickness="1"
                        CornerRadius="6">
                    <ListBox Classes="vault-list"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedEntry}"
                             Background="#0F1B2A"
                             Foreground="White"
                             BorderThickness="0"
                             MinHeight="260">

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent"
                                        BorderBrush="#182A40"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10">
                                    <Grid ColumnDefinitions="140,120,120,120"
                                          ColumnSpacing="16">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding UserName}"
                                                   Foreground="#C8D4E2"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Website}"
                                                   Foreground="#8DB7E8"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding UpdatedText}"
                                                   Foreground="#9EB4CC"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <TextBlock Grid.Row="4"
                           Text="{Binding VaultFilePath}"
                           Foreground="#5F7EA0"
                           FontSize="11"
                           TextWrapping="Wrap"
                           IsVisible="{Binding IsUnlocked}"/>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="#122238"
                BorderBrush="#2A405A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="22">

            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">

                    <TextBlock Text="Vault Entry"
                               Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8">
                        <Button Name="EditVaultEntryButton"
                                Content="Edit"
                                Height="34"
                                Padding="14,0"
                                Background="#17263A"
                                Foreground="#DDE7F3"
                                BorderBrush="#30445F"
                                IsEnabled="{Binding CanEditEntry}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>

                        <Button Name="RemoveVaultEntryButton"
                                Content="Remove"
                                Height="34"
                                Padding="14,0"
                                Background="#8B2E2E"
                                Foreground="White"
                                BorderBrush="#B84A4A"
                                IsEnabled="{Binding CanRemoveEntry}"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,24,0,0"
                              VerticalScrollBarVisibility="Auto">

                    <StackPanel Spacing="14">

                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <Grid ColumnDefinitions="150,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  RowSpacing="8">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" Foreground="#9EB4CC" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTitle}" Foreground="White" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Username" Foreground="#9EB4CC" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedUserName}" Foreground="White" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Website" Foreground="#9EB4CC" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedWebsite}" Foreground="#8DB7E8" TextWrapping="Wrap"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Created" Foreground="#9EB4CC" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedCreatedText}" Foreground="White"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Updated" Foreground="#9EB4CC" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedUpdatedText}" Foreground="White"/>
                            </Grid>
                        </Border>

                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Password"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding SelectedPasswordDisplay}"
                                           Foreground="#C8D4E2"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Public Notes"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding SelectedPublicNotes}"
                                           Foreground="#C8D4E2"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Secure Notes"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding SelectedSecureNotesDisplay}"
                                           Foreground="#C8D4E2"
                                           FontSize="13"
                                           TextWrapping="Wrap"/>

                                <WrapPanel Orientation="Horizontal"
                                           HorizontalAlignment="Left">
                                    <Button Name="RevealSecureNotesButton"
                                            Content="Reveal Secure Notes"
                                            Height="34"
                                            Padding="14,0"
                                            Margin="0,0,8,0"
                                            Background="#3A2F18"
                                            Foreground="#FFE7B0"
                                            IsEnabled="{Binding CanRevealSelectedSecureNotes}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>

                                    <Button Name="HideSecureNotesButton"
                                            Content="Hide Secure Notes"
                                            Height="34"
                                            Padding="14,0"
                                            Margin="0,0,8,0"
                                            Background="#17263A"
                                            Foreground="#DDE7F3"
                                            BorderBrush="#30445F"
                                            IsEnabled="{Binding CanHideSelectedSecureNotes}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#0F1B2A"
                                BorderBrush="#26384F"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Password Actions"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <WrapPanel Orientation="Horizontal"
                                           HorizontalAlignment="Left">
                                    <Button Name="CopyUserNameButton"
                                            Content="Copy Username"
                                            Height="34"
                                            Padding="14,0"
                                            Margin="0,0,8,0"
                                            Background="#2E8B57"
                                            Foreground="White"
                                            BorderBrush="#2E8B57"
                                            IsEnabled="{Binding CanCopySelectedUserName}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>

                                    <Button Name="CopyPasswordButton"
                                            Content="Copy Password"
                                            Height="34"
                                            Padding="14,0"
                                            Margin="0,0,8,0"
                                            Background="#2E8B57"
                                            Foreground="White"
                                            BorderBrush="#2E8B57"
                                            IsEnabled="{Binding CanCopySelectedPassword}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>

                                    <Button Name="RevealPasswordButton"
                                            Content="Reveal Password"
                                            Height="34"
                                            Padding="14,0"
                                            Margin="0,8,8,0"
                                            Background="#3A2F18"
                                            Foreground="#FFE7B0"
                                            IsEnabled="{Binding CanRevealSelectedPassword}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>

                                    <Button Name="HidePasswordButton"
                                            Content="Hide Password"
                                            Height="34"
                                            Padding="14,0"
                                            Margin="0,8,8,0"
                                            Background="#17263A"
                                            Foreground="#DDE7F3"
                                            BorderBrush="#30445F"
                                            IsEnabled="{Binding CanHideSelectedPassword}"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
